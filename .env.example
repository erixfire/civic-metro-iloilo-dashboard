# ─── Civic Metro Iloilo Dashboard — Environment Variables ───────────────────
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# ---- Admin Auth (required) --------------------------------------------------
# Long random string used to sign/verify JWT tokens for admin sessions.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ---- Push Notifications (optional) -----------------------------------------
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:it@iloilocity.gov.ph

# ---- Cloudflare (for local wrangler dev only) --------------------------------
# These are set automatically in CI/CD via GitHub Secrets.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
